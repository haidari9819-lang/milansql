# Normalize line endings
* text=auto

# Force Unix LF for source files
*.cpp text eol=lf
*.hpp text eol=lf
*.h   text eol=lf
*.py  text eol=lf
*.md  text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Binary files — no line ending conversion
*.exe binary
*.dll binary
*.so  binary
*.a   binary
*.lib binary
*.png binary
*.jpg binary
*.gif binary
